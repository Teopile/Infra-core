# ---- Infra Core site environment ----
# Copy to .env.local for local dev, and set the same vars in Vercel / GitHub Actions.

# Web3Forms access key for the contact form (used client-side, so it is public).
# Get a free key at https://web3forms.com (enter info@infracore-consulting.com as the recipient).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Floating quick-contact buttons (optional)
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/
NEXT_PUBLIC_WHATSAPP_NUMBER=995500000000

# Public phone shown on the site (display + tel: link)
NEXT_PUBLIC_PHONE_DISPLAY=+995 5XX XX XX XX
NEXT_PUBLIC_PHONE_TEL=+995500000000
